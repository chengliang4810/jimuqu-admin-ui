{
  "name": "ruoyi-plus-antdv",
  "version": "2.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "dev": "vite --mode development",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build --mode production",
    "build:test": "vite build --mode test",
    "build:analyze": "vite build --mode analyze",
    "prepare:internal": "pnpm --filter @vben/node-utils stub && pnpm --filter @vben/vite-config stub",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "check:cspell": "cspell lint \"**/*.ts\" \"**/README.md\" \".changeset/*.md\" --no-progress",
    "clean": "node ./scripts/clean.mjs",
    "format": "vsh lint --format",
    "lint": "vsh lint",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm run prepare:internal",
    "reinstall": "pnpm run clean -- --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "catalog": "pnpm dlx codemod pnpm/catalog",
    "generate-offline-icons": "node scripts/generate-offline-icons.js"
  },
  "imports": {
    "@/*": "./src/*"
  },
  "dependencies": {
